<% content_for(:title) { "Account" } %>

<div class="page-header">
  <h1>Account</h1>
</div>

<h2 class="section-title">Your API Key</h2>
<div class="card" style="padding: 1rem 1.25rem;">
  <p style="margin: 0 0 0.5rem; font-size: 0.85rem; color: var(--text-muted);">
    This key gives read/write access to <strong>all projects</strong>. Use it with the CLI or any API integration.
  </p>
  <code class="api-key-display"><%= @user.api_key %></code>
  <p style="margin: 0.75rem 0 0; font-size: 0.8rem; color: var(--text-muted);">
    <strong>Authorization header:</strong>
    <code>Bearer <%= @user.api_key %></code>
  </p>
</div>

<h2 class="section-title">Profile</h2>
<div class="card" style="padding: 1rem 1.25rem;">
  <p style="margin: 0; font-size: 0.9rem;">
    <strong>Email:</strong> <%= @user.email_address %>
  </p>
</div>
