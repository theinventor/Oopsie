<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Oopsie" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Oopsie">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="top-nav">
      <div class="nav-inner">
        <%= link_to "Oopsie", root_path, class: "nav-brand" %>
        <div class="nav-links">
          <% if authenticated? %>
            <%= link_to "Projects", root_path %>
            <%= button_to "Log out", session_path, method: :delete, class: "btn-link" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="container">
      <% if notice.present? %>
        <div class="flash flash-notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash flash-alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
