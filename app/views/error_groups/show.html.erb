<div class="page-header">
  <div>
    <div class="breadcrumb">
      <%= link_to @project.name, project_path(@project) %> &rsaquo; Error Group
    </div>
    <h1 class="error-class" style="font-size: 1.4rem;"><%= @error_group.error_class %></h1>
    <% if @error_group.message.present? %>
      <p class="error-group-message"><%= @error_group.message %></p>
    <% end %>
  </div>
  <div class="status-actions">
    <span class="badge badge-<%= status_badge_class(@error_group.status) %>"><%= @error_group.status %></span>
    <span class="badge badge-<%= workflow_state_badge_class(@error_group.workflow_state) %>"><%= workflow_state_label(@error_group.workflow_state) %></span>
    <% if @error_group.unresolved? %>
      <%= button_to "Resolve", resolve_project_error_group_path(@project, @error_group), method: :patch, class: "btn btn-sm btn-secondary" %>
      <%= button_to "Ignore", ignore_project_error_group_path(@project, @error_group), method: :patch, class: "btn btn-sm btn-secondary" %>
    <% else %>
      <%= button_to "Reopen", unresolve_project_error_group_path(@project, @error_group), method: :patch, class: "btn btn-sm btn-primary" %>
    <% end %>
  </div>
</div>

<h2 class="section-title">Workflow</h2>
<div class="workflow-grid">
  <div class="card workflow-card">
    <h3>State</h3>
    <p class="workflow-meta">Last changed <%= time_ago_in_words(@error_group.workflow_state_changed_at) %> ago</p>
    <%= form_with url: workflow_state_project_error_group_path(@project, @error_group), method: :patch, local: true do |form| %>
      <div class="form-group">
        <%= form.label :workflow_state, "Workflow state" %>
        <%= form.select :workflow_state,
              ErrorGroup.workflow_states.keys.map { |state| [workflow_state_label(state), state] },
              { selected: @error_group.workflow_state },
              class: "form-select" %>
      </div>
      <div class="form-group">
        <%= form.label :note, "Optional note" %>
        <%= form.text_area :note, rows: 3, placeholder: "Why is this state changing?" %>
      </div>
      <%= form.submit "Update workflow", class: "btn btn-primary" %>
    <% end %>
  </div>

  <div class="card workflow-card">
    <h3>Add note</h3>
    <p class="workflow-meta">Leave investigation evidence without resolving or ignoring this group.</p>
    <%= form_with model: ErrorGroupNote.new, url: project_error_group_notes_path(@project, @error_group), local: true do |form| %>
      <div class="form-group">
        <%= form.label :body, "Note" %>
        <%= form.text_area :body, rows: 5, placeholder: "Observed behavior, suspected cause, links, or verification notes." %>
      </div>
      <%= form.submit "Add note", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<% if @activity.any? %>
  <h2 class="section-title">Recent Activity</h2>
  <div class="card activity-list">
    <% @activity.each do |activity| %>
      <div class="activity-item">
        <div class="activity-header">
          <span class="activity-kind"><%= activity.kind.humanize %></span>
          <span class="activity-meta">
            <%= activity.actor_label %> via <%= activity.source %> · <%= time_ago_in_words(activity.created_at) %> ago
          </span>
        </div>
        <% if activity.from_value.present? || activity.to_value.present? %>
          <div class="activity-transition">
            <code><%= activity.from_value || "none" %></code> → <code><%= activity.to_value || "none" %></code>
          </div>
        <% end %>
        <% if activity.body.present? %>
          <div class="activity-body"><%= simple_format(activity.body) %></div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<div class="error-stats">
  <div class="stat">
    <span class="stat-value"><%= @error_group.occurrences_count %></span>
    <span class="stat-label">Total occurrences</span>
  </div>
  <div class="stat">
    <span class="stat-value"><%= time_ago_in_words(@error_group.first_seen_at) %> ago</span>
    <span class="stat-label">First seen</span>
  </div>
  <div class="stat">
    <span class="stat-value"><%= time_ago_in_words(@error_group.last_seen_at) %> ago</span>
    <span class="stat-label">Last seen</span>
  </div>
</div>

<% if @latest %>
  <h2 class="section-title">Latest Backtrace</h2>
  <div class="card backtrace-card">
    <% backtrace = @latest.backtrace.is_a?(String) ? (JSON.parse(@latest.backtrace) rescue []) : Array(@latest.backtrace) %>
    <% if backtrace.any? %>
      <% backtrace.each_with_index do |frame, i| %>
        <div class="backtrace-frame <%= i == 0 ? 'backtrace-frame-top' : '' %>">
          <span class="frame-number"><%= i + 1 %></span>
          <code><%= frame %></code>
        </div>
      <% end %>
    <% else %>
      <div style="padding: 1rem; color: var(--text-muted);">No backtrace available.</div>
    <% end %>
  </div>

  <% ctx = @latest.context.is_a?(String) ? (JSON.parse(@latest.context) rescue nil) : @latest.context %>
  <% if ctx.present? && ctx.respond_to?(:any?) && ctx.any? %>
    <h2 class="section-title">Context</h2>
    <div class="card" style="overflow: hidden;">
      <pre class="context-json"><%= JSON.pretty_generate(ctx) %></pre>
    </div>
  <% end %>

  <% srv = @latest.server_info.is_a?(String) ? (JSON.parse(@latest.server_info) rescue nil) : @latest.server_info %>
  <% if srv.present? && srv.respond_to?(:any?) && srv.any? %>
    <h2 class="section-title">Server</h2>
    <div class="card" style="overflow: hidden;">
      <pre class="context-json"><%= JSON.pretty_generate(srv) %></pre>
    </div>
  <% end %>
<% end %>

<h2 class="section-title">Occurrences (<%= @occurrences.size %><%= " most recent" if @occurrences.size >= 50 %>)</h2>
<% if @occurrences.any? %>
  <div class="card" style="overflow-x: auto;">
    <table class="error-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Message</th>
          <th>Environment</th>
          <th>Handled</th>
        </tr>
      </thead>
      <tbody>
        <% @occurrences.each do |occ| %>
          <tr>
            <td class="error-time"><%= occ.occurred_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
            <td style="max-width: 400px;"><%= truncate(occ.message || "", length: 100) %></td>
            <td><%= occ.environment || "—" %></td>
            <td><%= occ.handled ? "Yes" : "No" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
