# Required in production
SECRET_KEY_BASE=generate-with-bin/rails-secret
OOPSIE_HOST=oopsie.yoursite.com
OOPSIE_FROM_EMAIL=Oopsie <notifications@yoursite.com>

# Postmark (outbound email notifications)
POSTMARK_API_TOKEN=your-postmark-server-api-token

# Admin user (first db:seed only)
OOPSIE_ADMIN_EMAIL=admin@example.com
OOPSIE_ADMIN_PASSWORD=change-me

# Optional
OOPSIE_RETENTION_DAYS=90
OOPSIE_SKIP_DEMO=0
